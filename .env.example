# Supabase (REQUIRED)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Server-only — required for admin photo uploads, member delete, etc.
# Supabase Dashboard → Project Settings → API → service_role (secret)
# Add this in Vercel → Project Settings → Environment Variables too.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Web Push (admin membership alerts) — generate with: npx web-push generate-vapid-keys
# Public key is safe in the browser; private key is server-only (Vercel env).
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# Optional contact for VAPID (mailto: or https:// site URL)
# VAPID_SUBJECT=mailto:Firstbaptist646@gmail.com

# Optional future services
# NEXT_PUBLIC_RESEND_API_KEY=
# ZEFFY_FORM_ID=
